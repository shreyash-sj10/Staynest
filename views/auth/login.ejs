<% layout("/layout/boilerplate.ejs") %>

<section class="mx-auto flex min-h-[82vh] max-w-7xl items-center justify-center px-6 py-14 lg:px-8">
  <div class="grid w-full max-w-5xl overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-2xl shadow-slate-200/70 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="hidden bg-slate-900 p-10 text-white lg:flex lg:flex-col lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-200">Welcome Back</p>
        <h1 class="mt-4 text-4xl font-bold leading-tight">Sign in to manage your listings and reviews.</h1>
        <p class="mt-4 text-sm leading-7 text-slate-300">
          Continue your hosting journey or discover stays through a clean, secure travel experience.
        </p>
      </div>
      <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 text-sm text-slate-300">
        Local authentication and Google OAuth are both available, backed by Passport and persistent Mongo sessions.
      </div>
    </div>

    <div class="p-8 sm:p-10 lg:p-12">
      <div class="max-w-md">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-500">Account Access</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">Login</h2>
        <p class="mt-3 text-sm leading-7 text-slate-600">Sign in with your username and password or continue with Google.</p>
      </div>

      <form action="/auth/login" method="POST" class="mt-8 space-y-5">
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="username">Username</label>
          <input class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="username" type="text" name="username" required />
        </div>

        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="password">Password</label>
          <input class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="password" type="password" name="password" required />
        </div>

        <button class="inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-slate-700" type="submit">
          Login
        </button>
      </form>

      <div class="my-6 flex items-center gap-4 text-xs font-semibold uppercase tracking-[0.3em] text-slate-400">
        <span class="h-px flex-1 bg-slate-200"></span>
        or
        <span class="h-px flex-1 bg-slate-200"></span>
      </div>

      <a href="/auth/google" class="inline-flex w-full items-center justify-center rounded-full border border-slate-300 px-6 py-3.5 text-sm font-semibold text-slate-700 transition hover:border-slate-900 hover:text-slate-900">
        <i class="fa-brands fa-google mr-3 text-base"></i>
        Login with Google
      </a>

      <p class="mt-6 text-sm text-slate-500">
        New here?
        <a class="font-semibold text-slate-900 underline" href="/auth/signup">Create an account</a>
      </p>
    </div>
  </div>
</section>
