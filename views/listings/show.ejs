<% layout("/layout/boilerplate.ejs") %>

<section class="mx-auto max-w-6xl px-6 py-14 lg:px-8">
  <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
    <div class="space-y-8">
      <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
        <img
          class="h-[320px] w-full object-cover sm:h-[420px]"
          src="<%= myListings.image.url %>"
          alt="<%= myListings.title %>"
        />
      </div>

      <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-500">Stay Details</p>
            <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"><%= myListings.title %></h1>
            <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-slate-500">
              <span class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-4 py-2">
                <i class="fa-solid fa-location-dot text-rose-500"></i>
                <%= myListings.location %>, <%= myListings.country %>
              </span>
              <% if (myListings.owner) { %>
                <span class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-4 py-2">
                  <i class="fa-regular fa-user text-rose-500"></i>
                  Hosted by <%= myListings.owner.username %>
                </span>
              <% } %>
            </div>
          </div>
          <div class="rounded-[1.5rem] bg-slate-900 px-6 py-5 text-white shadow-sm">
            <p class="text-xs uppercase tracking-[0.25em] text-slate-300">Price</p>
            <p class="mt-2 text-2xl font-bold">$<%= myListings.price %><span class="text-sm font-medium text-slate-300"> / night</span></p>
          </div>
        </div>

        <div class="mt-8 grid gap-6 border-t border-slate-200 pt-8 sm:grid-cols-3">
          <div class="rounded-[1.5rem] bg-slate-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">Category</p>
            <p class="mt-2 text-lg font-bold text-slate-900">Signature Stay</p>
          </div>
          <div class="rounded-[1.5rem] bg-slate-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">Experience</p>
            <p class="mt-2 text-lg font-bold text-slate-900">Comfort-first</p>
          </div>
          <div class="rounded-[1.5rem] bg-slate-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">Visibility</p>
            <p class="mt-2 text-lg font-bold text-slate-900">Public Listing</p>
          </div>
        </div>

        <div class="mt-8 border-t border-slate-200 pt-8">
          <h2 class="text-xl font-bold text-slate-900">About this stay</h2>
          <p class="mt-4 text-sm leading-8 text-slate-600"><%= myListings.description %></p>
        </div>

        <% if (currentUser && myListings.owner && String(currentUser._id) === String(myListings.owner._id)) { %>
          <div class="mt-8 flex flex-wrap gap-3 border-t border-slate-200 pt-8">
            <form action="/listings/<%= myListings._id %>/edit" method="GET">
              <button class="inline-flex items-center justify-center rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-900 hover:text-slate-900">
                Edit Listing
              </button>
            </form>
            <form action="/listings/<%= myListings._id %>?_method=DELETE" method="POST">
              <button class="inline-flex items-center justify-center rounded-full bg-rose-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-rose-600">
                Delete Listing
              </button>
            </form>
          </div>
        <% } %>
      </div>
    </div>

    <div class="space-y-6">
      <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-500">Guest Reviews</p>
            <h2 class="mt-2 text-2xl font-bold text-slate-900">Share your experience</h2>
          </div>
          <div class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-600">
            <%= myListings.reviews.length %> review<%= myListings.reviews.length === 1 ? "" : "s" %>
          </div>
        </div>

        <% if (currentUser) { %>
          <form class="mt-8 space-y-5" action="/listings/<%= myListings._id %>/reviews" method="POST">
            <div>
              <label class="mb-2 block text-sm font-semibold text-slate-700" for="rating">Rating</label>
              <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 px-4 py-4">
                <input
                  class="w-full accent-rose-500"
                  type="range"
                  id="rating"
                  name="review[rating]"
                  min="1"
                  max="5"
                  step="1"
                  required
                />
              </div>
            </div>

            <div>
              <label class="mb-2 block text-sm font-semibold text-slate-700" for="comments">Comments</label>
              <textarea
                class="min-h-[140px] w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10"
                id="comments"
                name="review[comments]"
                placeholder="Write your thoughts..."
                required
              ></textarea>
            </div>

            <button class="inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-slate-700" type="submit">
              Submit Review
            </button>
          </form>
        <% } else { %>
          <div class="mt-8 rounded-[1.5rem] border border-dashed border-slate-300 bg-slate-50 p-6 text-sm leading-7 text-slate-600">
            Please <a class="font-semibold text-slate-900 underline" href="/auth/login">log in</a> to add a review.
          </div>
        <% } %>
      </div>

      <div class="space-y-4">
        <% if (myListings.reviews.length === 0) { %>
          <div class="rounded-[2rem] border border-slate-200 bg-white p-6 text-sm text-slate-500 shadow-sm">
            No reviews yet. Be the first guest to leave feedback.
          </div>
        <% } %>
        <% for (let review of myListings.reviews) { %>
          <article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-md">
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="flex items-center gap-3">
                  <p class="text-lg font-bold text-slate-900"><%= review.rating %> / 5</p>
                  <span class="text-amber-500">
                    <% for (let i = 0; i < review.rating; i++) { %>
                      <i class="fa-solid fa-star"></i>
                    <% } %>
                  </span>
                </div>
                <% if (review.author) { %>
                  <p class="mt-2 text-xs font-semibold uppercase tracking-[0.25em] text-slate-400"><%= review.author.username %></p>
                <% } %>
              </div>
              <% if (currentUser && review.author && String(currentUser._id) === String(review.author._id)) { %>
                <form action="/listings/<%= myListings._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                  <button class="rounded-full border border-rose-200 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-rose-500 transition hover:border-rose-500 hover:bg-rose-50">
                    Delete
                  </button>
                </form>
              <% } %>
            </div>
            <p class="mt-4 text-sm leading-7 text-slate-600"><%= review.comments %></p>
          </article>
        <% } %>
      </div>
    </div>
  </div>
</section>
