<% layout("/layout/boilerplate.ejs") %>

<section class="relative overflow-hidden">
  <div class="mx-auto grid max-w-7xl gap-12 px-6 py-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:px-8 lg:py-24">
    <div class="max-w-2xl space-y-8">
      <div class="inline-flex items-center rounded-full border border-rose-200 bg-white/80 px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm backdrop-blur">
        Portfolio-ready stays, polished like a product
      </div>
      <div class="space-y-5">
        <h1 class="text-4xl font-extrabold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">
          Discover remarkable stays with a cleaner, safer booking-inspired experience.
        </h1>
        <p class="max-w-xl text-base leading-8 text-slate-600 sm:text-lg">
          Wanderlust blends curated property discovery, secure authentication, and a refined UI so every listing feels trustworthy, modern, and ready to explore.
        </p>
      </div>
      <div class="flex flex-col gap-4 sm:flex-row">
        <a
          href="/listings"
          class="inline-flex items-center justify-center rounded-full bg-slate-900 px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-slate-700"
        >
          Start Exploring
        </a>
        <% if (!currentUser) { %>
          <a
            href="/auth/signup"
            class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-3.5 text-sm font-semibold text-slate-700 transition hover:border-slate-900 hover:text-slate-900"
          >
            Create an Account
          </a>
        <% } %>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-[1.5rem] border border-slate-200 bg-white/85 p-5 shadow-sm backdrop-blur">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">Trusted UI</p>
          <p class="mt-2 text-2xl font-bold text-slate-900">Modern</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Structured details, intuitive flows, and strong visual clarity.</p>
        </div>
        <div class="rounded-[1.5rem] border border-slate-200 bg-white/85 p-5 shadow-sm backdrop-blur">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">Uploads</p>
          <p class="mt-2 text-2xl font-bold text-slate-900">Cloudinary</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">High-quality listing imagery with real hosted media support.</p>
        </div>
        <div class="rounded-[1.5rem] border border-slate-200 bg-white/85 p-5 shadow-sm backdrop-blur">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">Security</p>
          <p class="mt-2 text-2xl font-bold text-slate-900">Protected</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Authentication, sessions, and secure middleware already built in.</p>
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="absolute -inset-6 -z-10 rounded-[2.5rem] bg-gradient-to-br from-rose-100 via-amber-50 to-sky-100 blur-2xl"></div>
      <div class="overflow-hidden rounded-[2.25rem] border border-white/60 bg-white/85 p-4 shadow-2xl shadow-slate-200/70 backdrop-blur">
        <img
          class="h-[520px] w-full rounded-[1.75rem] object-cover"
          src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=1200&q=80"
          alt="Scenic travel destination"
        />
        <div class="-mt-24 mx-4 rounded-[1.75rem] border border-white/70 bg-white/90 p-6 shadow-lg backdrop-blur">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-rose-500">Featured Experience</p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-slate-900">Curated stays with better presentation and clearer trust signals.</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            Browse listings, review hosts, and explore a polished travel interface designed to feel both aspirational and practical.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-500">Features</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">A travel app experience shaped for clarity and confidence.</h2>
      <p class="mt-4 text-sm leading-7 text-slate-600">
        Every section is tuned for easier browsing, stronger visual hierarchy, and a consistent portfolio-grade feel.
      </p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-200/70">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-rose-100 text-xl text-rose-500">
          <i class="fa-solid fa-map-location-dot"></i>
        </div>
        <h3 class="mt-6 text-xl font-bold text-slate-900">Curated Discovery</h3>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Explore stays through spacious cards, cleaner imagery, and clearer pricing information.
        </p>
      </article>
      <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-200/70">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-100 text-xl text-sky-500">
          <i class="fa-solid fa-user-shield"></i>
        </div>
        <h3 class="mt-6 text-xl font-bold text-slate-900">Secure Access</h3>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Local auth, Google OAuth, session persistence, and security middleware keep the app dependable.
        </p>
      </article>
      <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-200/70">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-100 text-xl text-amber-500">
          <i class="fa-solid fa-image"></i>
        </div>
        <h3 class="mt-6 text-xl font-bold text-slate-900">Real Media Uploads</h3>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Cloudinary-backed image uploads make listings feel more authentic and production-minded.
        </p>
      </article>
    </div>
  </div>
</section>

<section class="py-16">
  <div class="mx-auto max-w-6xl px-6 lg:px-8">
    <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-900 px-8 py-12 text-white shadow-2xl shadow-slate-200/70 sm:px-10">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-200">Call To Action</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Start exploring standout properties built into a polished full-stack experience.</h2>
          <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
            Browse the latest stays, inspect the UI flow, and experience a project designed to feel deployment-ready from the first click.
          </p>
        </div>
        <div class="flex flex-col gap-4">
          <a
            href="/listings"
            class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3.5 text-sm font-semibold text-slate-900 transition hover:bg-rose-100"
          >
            Explore Listings
          </a>
          <% if (!currentUser) { %>
            <a
              href="/auth/signup"
              class="inline-flex items-center justify-center rounded-full border border-slate-500 px-6 py-3.5 text-sm font-semibold text-white transition hover:border-white hover:bg-white/5"
            >
              Join Wanderlust
            </a>
          <% } else { %>
            <a
              href="/listings/new"
              class="inline-flex items-center justify-center rounded-full border border-slate-500 px-6 py-3.5 text-sm font-semibold text-white transition hover:border-white hover:bg-white/5"
            >
              Publish a Listing
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="pb-4 pt-16">
  <div class="mx-auto max-w-6xl px-6 lg:px-8">
    <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
      <div class="grid gap-0 lg:grid-cols-[0.85fr_1.15fr]">
        <div class="relative min-h-[320px] overflow-hidden bg-slate-100">
          <img
            class="h-full w-full object-cover"
            src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=900&q=80"
            alt="Developer workspace placeholder"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 via-slate-950/10 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-rose-200">About the Developer</p>
            <h2 class="mt-2 text-3xl font-bold">Shreyash Jadhav</h2>
          </div>
        </div>

        <div class="p-8 sm:p-10">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-500">Full-Stack Developer</p>
          <h3 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">Electronics and Telecommunication engineering student building polished web products.</h3>
          <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600">
            Shreyash Jadhav is an Electronics and Telecommunication engineering student and full-stack developer focused on building clean, secure, user-friendly applications with thoughtful UI, practical architecture, and production-inspired workflows.
          </p>

          <div class="mt-8">
            <p class="text-sm font-semibold text-slate-900">Tech Stack</p>
            <div class="mt-4 flex flex-wrap gap-3">
              <% ["Node.js", "Express", "MongoDB", "EJS", "Tailwind", "Cloudinary"].forEach((tag) => { %>
                <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 ring-1 ring-slate-200"><%= tag %></span>
              <% }) %>
            </div>
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a class="inline-flex items-center justify-center rounded-full border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-slate-900 hover:text-slate-900" href="https://github.com/yourusername" target="_blank" rel="noreferrer">
              <i class="fa-brands fa-github mr-2"></i>
              GitHub
            </a>
            <a class="inline-flex items-center justify-center rounded-full border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-slate-900 hover:text-slate-900" href="https://www.linkedin.com/in/yourusername" target="_blank" rel="noreferrer">
              <i class="fa-brands fa-linkedin mr-2"></i>
              LinkedIn
            </a>
            <a class="inline-flex items-center justify-center rounded-full border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-slate-900 hover:text-slate-900" href="https://leetcode.com/yourusername" target="_blank" rel="noreferrer">
              <i class="fa-solid fa-code mr-2"></i>
              LeetCode
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
