<% layout("/layout/boilerplate.ejs") %>

<section class="mx-auto max-w-3xl px-6 py-12 lg:px-8">
  <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-500">Host Dashboard</p>
      <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">Add a new listing</h1>
      <p class="mt-3 text-sm leading-7 text-slate-600">Share your stay with guests using a clean, compelling presentation.</p>
    </div>

    <form class="mt-8 grid gap-5" action="/listings" method="POST">
      <div>
        <label class="mb-2 block text-sm font-semibold text-slate-700" for="title">Title</label>
        <input class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="title" type="text" name="title" required />
      </div>
      <div>
        <label class="mb-2 block text-sm font-semibold text-slate-700" for="description">Description</label>
        <textarea class="min-h-[140px] w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="description" name="description" required></textarea>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="image">Image URL</label>
          <input class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="image" type="text" name="image" />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="price">Price</label>
          <input class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="price" type="text" name="price" required />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="location">Location</label>
          <input class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="location" type="text" name="location" required />
        </div>
        <div class="sm:col-span-2">
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="country">Country</label>
          <input class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="country" type="text" name="country" required />
        </div>
      </div>

      <button class="mt-2 inline-flex items-center justify-center rounded-full bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-700">
        Publish Listing
      </button>
    </form>
  </div>
</section>
