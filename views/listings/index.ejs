<% layout("/layout/boilerplate.ejs") %>

<section class="mx-auto max-w-7xl px-6 py-14 lg:px-8">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-500">Browse Stays</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Discover places guests would actually want to bookmark.</h1>
      <p class="mt-4 text-sm leading-7 text-slate-600 sm:text-base">
        Explore thoughtfully presented apartments, villas, cottages, and cabins with polished cards, clearer pricing, and responsive browsing.
      </p>
    </div>
    <% if (currentUser) { %>
      <a
        href="/listings/new"
        class="inline-flex items-center justify-center rounded-full bg-slate-900 px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-slate-700"
      >
        Add New Listing
      </a>
    <% } %>
  </div>

  <div class="mt-10 grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
    <% for (let list of allListings) { %>
      <a
        href="/listings/<%= list._id %>"
        class="group flex h-full flex-col overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-slate-200/70"
      >
        <div class="relative overflow-hidden">
          <img
            class="h-72 w-full object-cover transition duration-500 group-hover:scale-105"
            src="<%= list.image.url %>"
            alt="<%= list.title %>"
          />
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-slate-950/80 via-slate-900/20 to-transparent px-5 py-4">
            <p class="text-sm font-medium text-white/85"><%= list.location %>, <%= list.country %></p>
          </div>
        </div>
        <div class="flex flex-1 flex-col justify-between gap-5 p-5">
          <div>
            <div class="flex items-start justify-between gap-4">
              <h2 class="text-lg font-bold leading-7 text-slate-900"><%= list.title %></h2>
              <span class="shrink-0 rounded-full bg-rose-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.2em] text-rose-600">
                Stay
              </span>
            </div>
            <p class="mt-3 line-clamp-2 text-sm leading-6 text-slate-600"><%= list.description %></p>
          </div>
          <div class="flex items-center justify-between border-t border-slate-100 pt-4">
            <p class="text-sm font-medium text-slate-500">Starting from</p>
            <p class="text-lg font-bold text-slate-900">$<%= list.price %><span class="text-sm font-medium text-slate-500"> / night</span></p>
          </div>
        </div>
      </a>
    <% } %>
  </div>

  <% if (!allListings.length) { %>
    <div class="mt-10 rounded-[2rem] border border-dashed border-slate-300 bg-white p-10 text-center text-sm text-slate-500 shadow-sm">
      No listings available yet. Add the first one to start the collection.
    </div>
  <% } %>
</section>
