<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wanderlust</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css"
      integrity="sha512-DxV+EoADOkOygM4IR9yXP8Sb2qwgidEmeqAEmDKIOfPRQZOWbXCzLC6vjbZyy0vPisbH2SyW27+ddLVCN+OMzQ=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/CSS/style.css" />
    <style>
      body {
        font-family: "Plus Jakarta Sans", sans-serif;
      }
    </style>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800 antialiased">
    <div class="relative isolate min-h-screen overflow-x-hidden">
      <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-80 bg-gradient-to-b from-rose-100/70 via-white to-transparent"></div>
      <div class="pointer-events-none absolute right-0 top-24 -z-10 h-64 w-64 rounded-full bg-amber-100/40 blur-3xl"></div>
      <%- include("../includes/navbar.ejs") %>

      <% if (success && success.length) { %>
        <div class="mx-auto mt-6 w-full max-w-6xl px-6 lg:px-8">
          <div class="flex items-start gap-3 rounded-[1.5rem] border border-emerald-200 bg-emerald-50/90 px-5 py-4 text-sm font-medium text-emerald-700 shadow-sm backdrop-blur">
            <i class="fa-solid fa-circle-check mt-0.5 text-emerald-500"></i>
            <span><%= success[0] %></span>
          </div>
        </div>
      <% } %>

      <% if (error && error.length) { %>
        <div class="mx-auto mt-6 w-full max-w-6xl px-6 lg:px-8">
          <div class="flex items-start gap-3 rounded-[1.5rem] border border-rose-200 bg-rose-50/90 px-5 py-4 text-sm font-medium text-rose-700 shadow-sm backdrop-blur">
            <i class="fa-solid fa-circle-exclamation mt-0.5 text-rose-500"></i>
            <span><%= error[0] %></span>
          </div>
        </div>
      <% } %>

      <main><%- body %></main>
      <%- include("../includes/footer.ejs") %>
    </div>
  </body>
</html>
