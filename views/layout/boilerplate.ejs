<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wanderlust</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css"
      integrity="sha512-DxV+EoADOkOygM4IR9yXP8Sb2qwgidEmeqAEmDKIOfPRQZOWbXCzLC6vjbZyy0vPisbH2SyW27+ddLVCN+OMzQ=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/CSS/style.css" />
  </head>
  <body class="bg-slate-50 text-slate-800 antialiased">
    <%- include("../includes/navbar.ejs") %>
    <% if (success && success.length) { %>
      <div class="mx-auto mt-6 w-full max-w-4xl px-6 lg:px-8">
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-medium text-emerald-700 shadow-sm">
          <%= success[0] %>
        </div>
      </div>
    <% } %>
    <% if (error && error.length) { %>
      <div class="mx-auto mt-6 w-full max-w-4xl px-6 lg:px-8">
        <div class="rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm font-medium text-rose-700 shadow-sm">
          <%= error[0] %>
        </div>
      </div>
    <% } %>
    <main class="min-h-screen"><%-body%></main>
    <%- include("../includes/footer.ejs") %>
  </body>
</html>
