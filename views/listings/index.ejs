<% layout("/layout/boilerplate.ejs") %>

<section class="mx-auto max-w-7xl px-6 py-12 lg:px-8">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-500">Browse Stays</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Discover places guests love to stay.
      </h1>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-600">
        Explore curated apartments, villas, cottages, and cabins with transparent pricing and host details.
      </p>
    </div>
    <% if (currentUser) { %>
      <a
        href="/listings/new"
        class="inline-flex items-center justify-center rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-700"
      >
        Add New Listing
      </a>
    <% } %>
  </div>

  <div class="mt-10 grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
    <% for (let list of allListings) { %>
      <a
        href="/listings/<%= list._id %>"
        class="group overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-200/70"
      >
        <div class="relative overflow-hidden">
          <img
            class="h-72 w-full object-cover transition duration-500 group-hover:scale-105"
            src="<%= list.image.url %>"
            alt="<%= list.title %>"
          />
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-slate-950/60 to-transparent px-5 py-4">
            <p class="text-sm font-medium text-white/80"><%= list.location %>, <%= list.country %></p>
          </div>
        </div>
        <div class="space-y-3 p-5">
          <div class="flex items-start justify-between gap-4">
            <h2 class="text-lg font-semibold text-slate-900"><%= list.title %></h2>
            <span class="rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-rose-600">
              Featured
            </span>
          </div>
          <div class="flex items-center justify-between">
            <p class="text-sm text-slate-500">Starting from</p>
            <p class="text-lg font-bold text-slate-900">$<%= list.price %><span class="text-sm font-medium text-slate-500"> / night</span></p>
          </div>
        </div>
      </a>
    <% } %>
  </div>
</section>
