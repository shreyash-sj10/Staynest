<% layout("/layout/boilerplate.ejs") %>

<section class="relative overflow-hidden bg-white">
  <div class="absolute inset-x-0 top-0 -z-10 h-80 bg-gradient-to-b from-rose-50 to-transparent"></div>
  <div class="mx-auto flex max-w-7xl flex-col gap-12 px-6 py-16 lg:flex-row lg:items-center lg:px-8 lg:py-24">
    <div class="max-w-2xl space-y-8">
      <div class="inline-flex items-center rounded-full border border-rose-200 bg-rose-50 px-4 py-1 text-sm font-medium text-rose-600">
        Discover stays with personality
      </div>
      <div class="space-y-5">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
          Find your next stay with a modern Airbnb-inspired experience.
        </h1>
        <p class="max-w-xl text-lg leading-8 text-slate-600">
          Wanderlust helps guests explore verified listings, read authentic reviews, and book the feeling of home in a cleaner, safer way.
        </p>
      </div>
      <div class="flex flex-col gap-4 sm:flex-row">
        <a
          href="/listings"
          class="inline-flex items-center justify-center rounded-full bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-700"
        >
          Explore Listings
        </a>
        <% if (!currentUser) { %>
          <a
            href="/auth/signup"
            class="inline-flex items-center justify-center rounded-full border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-900 hover:text-slate-900"
          >
            Create an Account
          </a>
        <% } %>
      </div>
    </div>

    <div class="w-full max-w-xl self-center rounded-[2rem] border border-slate-200 bg-white p-5 shadow-xl shadow-slate-200/70">
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-[1.5rem] bg-[url('https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=900&q=80')] bg-cover bg-center p-5 text-white shadow-md sm:col-span-2">
          <div class="rounded-[1.25rem] bg-black/35 p-5 backdrop-blur-sm">
            <p class="text-sm uppercase tracking-[0.3em] text-rose-100">Featured Escape</p>
            <h2 class="mt-3 text-2xl font-semibold">Curated homes, thoughtful design, trusted hosts.</h2>
          </div>
        </div>
        <div class="rounded-[1.5rem] bg-slate-50 p-5">
          <p class="text-sm font-medium text-slate-500">Stay Types</p>
          <p class="mt-2 text-3xl font-bold text-slate-900">30+</p>
          <p class="mt-2 text-sm text-slate-600">Cabins, lofts, villas, beach houses, and more.</p>
        </div>
        <div class="rounded-[1.5rem] bg-rose-50 p-5">
          <p class="text-sm font-medium text-rose-500">Guest Trust</p>
          <p class="mt-2 text-3xl font-bold text-slate-900">Secure</p>
          <p class="mt-2 text-sm text-slate-600">Authentication, reviews, and protected sessions built in.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-slate-50 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-500">Why Wanderlust</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Everything you need for a polished rental experience.
      </h2>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-rose-100 text-xl text-rose-500">
          <i class="fa-solid fa-shield-heart"></i>
        </div>
        <h3 class="mt-6 text-xl font-semibold text-slate-900">Verified Listings</h3>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Browse thoughtfully presented stays with rich details, transparent pricing, and host information.
        </p>
      </article>
      <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-100 text-xl text-sky-500">
          <i class="fa-solid fa-lock"></i>
        </div>
        <h3 class="mt-6 text-xl font-semibold text-slate-900">Secure Experience</h3>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Passport authentication, Mongo-backed sessions, and secure middleware keep the app portfolio-ready and safe.
        </p>
      </article>
      <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-100 text-xl text-amber-500">
          <i class="fa-solid fa-comments"></i>
        </div>
        <h3 class="mt-6 text-xl font-semibold text-slate-900">User Reviews</h3>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Guests can leave ratings and comments, helping others make informed decisions with authentic social proof.
        </p>
      </article>
    </div>
  </div>
</section>

<section class="bg-white py-16">
  <div class="mx-auto max-w-5xl px-6 lg:px-8">
    <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-900 px-8 py-12 text-white shadow-xl shadow-slate-200/80">
      <div class="grid gap-10 lg:grid-cols-[1.3fr_0.7fr] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-200">Start Hosting</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
            Join the platform and publish your first standout listing.
          </h2>
          <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
            Create an account, add your property details, and build trust with travelers through polished listings and reviews.
          </p>
        </div>
        <div class="flex flex-col gap-4">
          <a
            href="/auth/signup"
            class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:bg-rose-100"
          >
            Sign Up Now
          </a>
          <a
            href="/listings"
            class="inline-flex items-center justify-center rounded-full border border-slate-500 px-6 py-3 text-sm font-semibold text-white transition hover:border-white"
          >
            View Listings
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-slate-50 py-16">
  <div class="mx-auto max-w-5xl px-6 lg:px-8">
    <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
      <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-slate-500">About Developer</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">Built like a portfolio project, designed like a real product.</h2>
          <p class="mt-4 text-sm leading-7 text-slate-600">
            This project showcases full-stack development with authentication, authorization, MongoDB-backed sessions, MVC architecture, and a modern EJS-driven UI focused on usability and clean presentation.
          </p>
        </div>
        <div class="rounded-[1.5rem] bg-slate-50 p-6 lg:w-80">
          <p class="text-sm font-semibold text-slate-900">Tech Stack</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <% ["Node.js", "Express", "MongoDB", "Mongoose", "EJS", "Passport", "Tailwind CSS"].forEach((tag) => { %>
              <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-700 ring-1 ring-slate-200"><%= tag %></span>
            <% }) %>
          </div>
          <div class="mt-6 flex flex-wrap gap-3 text-sm font-medium text-slate-700">
            <a class="rounded-full border border-slate-300 px-4 py-2 transition hover:border-slate-900 hover:text-slate-900" href="https://github.com/yourusername" target="_blank" rel="noreferrer">GitHub</a>
            <a class="rounded-full border border-slate-300 px-4 py-2 transition hover:border-slate-900 hover:text-slate-900" href="https://www.linkedin.com/in/yourusername" target="_blank" rel="noreferrer">LinkedIn</a>
            <a class="rounded-full border border-slate-300 px-4 py-2 transition hover:border-slate-900 hover:text-slate-900" href="https://leetcode.com/yourusername" target="_blank" rel="noreferrer">LeetCode</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
