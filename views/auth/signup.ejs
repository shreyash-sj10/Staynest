<% layout("/layout/boilerplate.ejs") %>

<section class="mx-auto flex min-h-[80vh] max-w-7xl items-center justify-center px-6 py-12 lg:px-8">
  <div class="grid w-full max-w-5xl overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-xl shadow-slate-200/70 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="hidden bg-rose-500 p-10 text-white lg:flex lg:flex-col lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-100">Join Wanderlust</p>
        <h1 class="mt-4 text-4xl font-bold leading-tight">Create your account and start hosting with confidence.</h1>
        <p class="mt-4 text-sm leading-7 text-rose-50/90">
          Set up your profile, add polished listings, and build trust with secure authentication and reviews.
        </p>
      </div>
      <div class="rounded-[1.5rem] border border-white/20 bg-white/10 p-5 text-sm text-rose-50">
        Designed as a portfolio-ready travel platform with modern UI, ownership checks, and persistent sessions.
      </div>
    </div>

    <div class="p-8 sm:p-10 lg:p-12">
      <div class="max-w-md">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-500">Create Account</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">Signup</h2>
        <p class="mt-3 text-sm leading-7 text-slate-600">Create a local account to manage your listings and reviews.</p>
      </div>

      <form action="/auth/signup" method="POST" class="mt-8 space-y-5">
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="name">Full Name</label>
          <input class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="name" type="text" name="name" required />
        </div>

        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="email">Email</label>
          <input class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="email" type="email" name="email" required />
        </div>

        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="username">Username</label>
          <input class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="username" type="text" name="username" required />
        </div>

        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="password">Password</label>
          <input class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none transition focus:border-slate-900 focus:ring-2 focus:ring-slate-900/10" id="password" type="password" name="password" minlength="6" required />
        </div>

        <button class="inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-700" type="submit">
          Create Account
        </button>
      </form>

      <p class="mt-6 text-sm text-slate-500">
        Already have an account?
        <a class="font-semibold text-slate-900 underline" href="/auth/login">Log in</a>
      </p>
    </div>
  </div>
</section>
